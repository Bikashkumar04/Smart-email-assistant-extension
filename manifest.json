{
  "manifest_version": 3,
  "name": "Smart Email Assistant",
  "description": "A chrome extension that provides smart email assistance for Gmail.",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:8080/*"
  ],

  "action": {
    "default_title": "Smart Email Assistant",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },


  "content_scripts": [
    {
      "css": ["content.css"],
      "js": ["content.js"],
      "matches": [
        "https://mail.google.com/*"
      ],
      "run_at": "document_end"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://mail.google.com/*"]
    }
  ]
}
